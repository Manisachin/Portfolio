/* ============================================================
   LOADER SECTION
   ============================================================ */
.loader-wrapper {
  position: fixed;
  inset: 0;
  background: var(--bg-base);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 10000;
  gap: 2rem;
}

.loader-logo {
  font-family: var(--font-heading);
  font-size: 3.5rem;
  font-weight: 800;
  color: var(--text-main);
  letter-spacing: -0.05em;
}

.loader-bar {
  height: 1px;
  background: var(--accent);
  box-shadow: 0 0 20px var(--accent-glow);
}

/* Hero Photo */
.hero-intro-row {
  display: flex;
  align-items: center;
  gap: 2rem;
  margin-bottom: 2rem;
}

.hero-photo-container {
  position: relative;
  width: 100px;
  height: 100px;
  flex-shrink: 0;
}

.hero-photo {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 50%;
  border: 3px solid var(--accent);
  position: relative;
  z-index: 2;
}

.photo-ring {
  position: absolute;
  inset: -8px;
  border: 1px dashed var(--accent);
  border-radius: 50%;
  animation: rotate 20s linear infinite;
  opacity: 0.5;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* Projects Image Refinement */
.project-image-detailed {
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0.8;
  transition: all var(--duration);
}

.project-case-study:hover .project-image-detailed {
  opacity: 1;
  transform: scale(1.05);
}

/* Education V2 */
.education-centered-layout {
  max-width: 800px;
  margin: 3rem auto 0;
}

.education-items-new {
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

.edu-item-card-v2 {
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-lg);
  padding: 2.5rem;
  position: relative;
  transition: all var(--duration);
}

.edu-item-card-v2:hover {
  border-color: var(--accent);
  background: var(--bg-card-hover);
}

.edu-card-content-v2 {
  display: flex;
  gap: 2rem;
  align-items: flex-start;
}

.edu-icon-v2 {
  width: 50px;
  height: 50px;
  background: var(--accent-subtle);
  color: var(--accent);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12px;
  font-size: 1.5rem;
  flex-shrink: 0;
}

.edu-details-v2 {
  flex: 1;
}

/* Contact Box */
.contact-box-main {
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-lg);
  padding: 5rem;
  position: relative;
  margin-top: 3rem;
}

/* Footer V2 */
.footer-top-v2 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 3rem;
  border-bottom: 1px solid var(--border-subtle);
}

.footer-brand-v2 p {
  color: var(--text-dim);
  font-size: 0.9375rem;
  margin-top: 0.5rem;
}

.footer-socials-v2 {
  display: flex;
  gap: 1rem;
}

.social-pill-v2 {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.75rem 1.5rem;
  background: var(--bg-base);
  border: 1px solid var(--border-subtle);
  border-radius: 100px;
  color: var(--text-main);
  text-decoration: none;
  font-family: var(--font-mono);
  font-size: 0.875rem;
  transition: all var(--duration);
}

.social-pill-v2:hover {
  border-color: var(--accent);
  color: var(--accent);
  transform: translateY(-3px);
}

.footer-bottom-v2 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 3rem;
  color: var(--text-muted);
  font-size: 0.875rem;
}

/* ============================================================
   GLOBAL RESPONSIVE REFINEMENTS
   ============================================================ */
@media (max-width: 1024px) {
  :root {
    --section-spacing: 80px;
  }
}

@media (max-width: 768px) {
  .section-title {
    font-size: 2rem;
  }
  
  .container {
    padding: 0 1.5rem;
  }
  
  .hero-intro-row {
    flex-direction: column;
    text-align: center;
  }
  
  .edu-card-content-v2 {
    flex-direction: column;
    gap: 1.5rem;
  }
  
  .contact-box-main {
    padding: 3rem 1.5rem;
  }
  
  .footer-top-v2 {
    flex-direction: column;
    text-align: center;
    gap: 2rem;
  }
  
  .footer-bottom-v2 {
    flex-direction: column;
    gap: 1rem;
    text-align: center;
  }
}
